# Frontend environment template — copy to .env.local for local development.
#
# When NEXT_PUBLIC_API_URL is set, the app talks to a real Fin-Sight backend.
# When unset, all pages fall back to the mock store (offline-friendly demo).

# Backend API base URL (FastAPI app at /api/v1).
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Default workspace ID to load on dashboard / workspace / analytics pages.
# In a multi-workspace deployment this would come from the user's profile.
NEXT_PUBLIC_DEFAULT_WORKSPACE_ID=

# Clerk publishable key — required if backend Clerk auth is enabled.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
