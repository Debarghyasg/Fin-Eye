# ============================================================
#  FinSight AI — Frontend environment (No-Docker Windows 11)
#  Copy this file to  frontend/.env.local  then fill in the keys.
#
#  REQUIRED:
#    NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY  → https://dashboard.clerk.com → API Keys
#    CLERK_SECRET_KEY                   → same page
# ============================================================

# Points the browser at your local FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Clerk keys — MUST match what you set in backend/.env
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# ── Clerk path configuration (REQUIRED for Google OAuth to work) ──────────────
# These tell Clerk where your sign-in / sign-up pages are.
# Without these, Google OAuth redirects back to the wrong URL.
#
# These MUST match what you set in the Clerk Dashboard:
#   Configure → Paths → Sign-in URL  = /sign-in
#   Configure → Paths → Sign-up URL  = /sign-up
#   Configure → Paths → After sign-in URL = /dashboard
#   Configure → Paths → After sign-up URL = /dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
