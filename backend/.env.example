# ============================================================
#  FinSight AI — Backend Environment Variables
#  100% FREE stack — no paid services required
# ============================================================
# Copy this file to .env and fill in the values marked REPLACE_ME.
# NEVER commit .env to git.
#
# Minimum required to start:
#   1. CLERK_SECRET_KEY + CLERK_PUBLISHABLE_KEY + CLERK_JWT_AUDIENCE
#   2. GROQ_API_KEY   ← free at https://console.groq.com  (takes 1 min)
#   3. Everything else has working defaults for local Docker dev
#
# Start the stack:
#   docker-compose up
# ============================================================


# ── App ──────────────────────────────────────────────────────
APP_NAME=FinSight AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO


# ── API ──────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ── Database ─────────────────────────────────────────────────
# Docker Compose sets this automatically — only change if using external Postgres
DATABASE_URL=postgresql+asyncpg://finsight:finsight_dev@localhost:5432/finsight
POSTGRES_USER=finsight
POSTGRES_PASSWORD=finsight_dev
POSTGRES_DB=finsight


# ── Clerk Authentication ──────────────────────────────────────
# Get from: https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_JWKS_URL=https://api.clerk.dev/v1/jwks
# Frontend API URL — shown in Clerk dashboard → API Keys
CLERK_JWT_AUDIENCE=


# ════════════════════════════════════════════════════════════
#  FREE SERVICES  (no credit card, no account for most)
# ════════════════════════════════════════════════════════════

# ── FREE: Groq LLM (Llama 3.1 70B) ──────────────────────────
# Sign up free at https://console.groq.com (takes 60 seconds)
# Free tier: 14,400 requests/day | 6,000 tokens/min
# Your key looks like: gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_REPLACE_ME
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant


# ── FREE: Local embeddings (HuggingFace all-MiniLM-L6-v2) ────
# No account needed — model downloads ~90 MB on first startup
# Runs entirely on CPU inside Docker
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384


# ── FREE: ChromaDB vector store ──────────────────────────────
# Runs in Docker Compose — no account, no API key
# Data persisted on the 'chromadata' Docker volume
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=finsight_chunks


# ── FREE: Redis (BM25 sparse index cache) ─────────────────────
# Runs in Docker Compose — no account
REDIS_URL=redis://localhost:6379/0
REDIS_BM25_TTL=604800


# ── FREE: Local file storage ──────────────────────────────────
# Files saved to /app/uploads inside Docker (persisted on 'uploads' volume)
# Set USE_S3=true and fill in AWS credentials below to switch to real S3
USE_S3=false
LOCAL_STORAGE_PATH=/app/uploads


# ── FREE: In-process task queue ───────────────────────────────
# Document processing runs as FastAPI BackgroundTasks (no SQS needed)
# Set USE_SQS=true to switch to real AWS SQS
USE_SQS=false


# ════════════════════════════════════════════════════════════
#  COMPLIANCE & DATA INTEGRITY  (PDF §10)
#  All free, all local, all map to AWS equivalents in production.
# ════════════════════════════════════════════════════════════

# ── Fernet encryption at rest ─────────────────────────────────
# AES-128-CBC + HMAC-SHA256. Maps 1:1 to AWS KMS CMK in production.
# Generate ONE key per environment, never commit, never rotate without re-keying:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to disable encryption (dev-only — production REQUIRES a key).
FERNET_KEY=
ENCRYPT_AT_REST=true

# ── Microsoft Presidio PII detection ──────────────────────────
# 50+ entity types via spaCy NER + 30+ regex patterns. MIT-licensed.
# Maps 1:1 to AWS Comprehend DetectPiiEntities in production.
# Falls back to internal regex scanner if Presidio import fails.
USE_PRESIDIO=true
PRESIDIO_LANGUAGE=en
PRESIDIO_MIN_SCORE=0.5
PRESIDIO_SPACY_MODEL=en_core_web_sm

# ── Audit log retention (SEC Rule 17a-4) ──────────────────────
# Records in audit_logs are tagged with expires_at = now() + N years
# for downstream TTL job cleanup. 7 years is the SEC requirement.
AUDIT_LOG_RETENTION_YEARS=7


# ── Re-ranker (cross-encoder, local CPU) ──────────────────────
# Downloads ~85 MB on first use, cached in Docker image layer
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5
RETRIEVER_TOP_K=20
RRF_K=60


# ── Document processing ───────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE_CHARS=800
CHUNK_OVERLAP_CHARS=150


# ════════════════════════════════════════════════════════════
#  OPTIONAL: AWS credentials (only needed if USE_S3=true)
#  Leave as-is for local dev — LocalStack uses "test"/"test"
# ════════════════════════════════════════════════════════════
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET_NAME=finsight-documents
SQS_DOCUMENT_QUEUE_URL=http://localhost:4566/000000000000/finsight-documents
