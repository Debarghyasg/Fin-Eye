# ============================================================
#  FinSight AI — Backend Environment Variables
#  Windows 11 local development (no Docker required)
# ============================================================
# Copy this file to .env and fill in the values marked REPLACE_ME.
# NEVER commit .env to git.
#
# Minimum required to start:
#   1. CLERK_SECRET_KEY + CLERK_PUBLISHABLE_KEY
#      → free at https://clerk.com  (2 minutes)
#   2. GROQ_API_KEY
#      → free at https://console.groq.com  (1 minute)
#   3. Everything else has working defaults for local dev
#
# Start order (see local_dev_windows.md for full guide):
#   1. PostgreSQL 16 (with pgvector extension)
#   2. uvicorn app.main:app --reload --port 8000
#   3. npm run dev  (frontend)
# ============================================================


# ── App ──────────────────────────────────────────────────────
APP_NAME=FinSight AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO


# ── API ──────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001


# ── Database ─────────────────────────────────────────────────
# Local PostgreSQL 16 — change user/password if you used different values
DATABASE_URL=postgresql+asyncpg://finsight:finsight_dev@localhost:5432/finsight
POSTGRES_USER=finsight
POSTGRES_PASSWORD=finsight_dev
POSTGRES_DB=finsight


# ── Clerk Authentication ──────────────────────────────────────
# Get from: https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_JWKS_URL=https://api.clerk.dev/v1/jwks
# Leave blank unless Clerk tells you to set it
CLERK_JWT_AUDIENCE=


# ════════════════════════════════════════════════════════════
#  FREE SERVICES  (no credit card, no account for most)
# ════════════════════════════════════════════════════════════

# ── FREE: Groq LLM (Llama 3.3 70B) ──────────────────────────
# Sign up free at https://console.groq.com (takes 60 seconds)
# Free tier: 14,400 requests/day | 6,000 tokens/min
# Your key looks like: gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_REPLACE_ME
# llama-3.1-70b-versatile was decommissioned by Groq — use llama-3.3-70b-versatile.
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant


# ── FREE: Local embeddings (HuggingFace all-MiniLM-L6-v2) ────
# No account needed — model downloads ~90 MB on first run
# Runs entirely on CPU
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384


# ── FREE: Qdrant vector store ─────────────────────────────────
# Download qdrant.exe from https://github.com/qdrant/qdrant/releases
# Run it with: ./qdrant.exe   (no config needed, listens on 6333)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=finsight_chunks
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
QDRANT_SPARSE_MODEL=Qdrant/bm25


# ── Redis (cache only — NOT the message broker) ──────────────
# Download from https://github.com/microsoftarchive/redis/releases
# Runs on port 6379 by default
REDIS_URL=redis://localhost:6379/0


# ── Celery task queue ─────────────────────────────────────────
# CELERY_TASK_ALWAYS_EAGER=true  → tasks run inline in the same process
#   ✅ Recommended for Windows dev — no RabbitMQ needed at all
#   ✅ Documents process synchronously (upload blocks until indexed)
#
# CELERY_TASK_ALWAYS_EAGER=false → tasks go to RabbitMQ broker
#   Requires RabbitMQ running on localhost:5672
#   Only needed if you want background async processing
CELERY_TASK_ALWAYS_EAGER=true
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=rpc://
CELERY_TASK_DEFAULT_QUEUE=finsight


# ── Local file storage ────────────────────────────────────────
# Uploaded PDFs and extracted JSON are saved here on your hard drive.
# Change this to any folder you want — it will be created automatically.
USE_S3=false
LOCAL_STORAGE_PATH=./uploads


# ── AWS (disabled by default) ─────────────────────────────────
# Only needed if you set USE_S3=true or USE_SQS=true (production upgrade)
USE_SQS=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=
S3_BUCKET_NAME=finsight-documents
SQS_DOCUMENT_QUEUE_URL=


# ── DynamoDB audit logging (disabled by default) ──────────────
USE_DYNAMODB=false
DYNAMODB_AUDIT_TABLE=finsight-query-audit
DYNAMODB_TTL_DAYS=2555


# ════════════════════════════════════════════════════════════
#  COMPLIANCE & DATA INTEGRITY
# ════════════════════════════════════════════════════════════

# ── Fernet encryption at rest ─────────────────────────────────
# Optional. Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to skip encryption in local dev.
FERNET_KEY=
ENCRYPT_AT_REST=false

# ── Microsoft Presidio PII scanner ────────────────────────────
# Uses spaCy en_core_web_sm — install it once with:
#   python -m spacy download en_core_web_sm
# Falls back to regex scanner if Presidio fails to import.
USE_PRESIDIO=true
PRESIDIO_LANGUAGE=en
PRESIDIO_MIN_SCORE=0.5
PRESIDIO_SPACY_MODEL=en_core_web_sm

# ── Audit log retention (SEC Rule 17a-4) ──────────────────────
AUDIT_LOG_RETENTION_YEARS=7


# ════════════════════════════════════════════════════════════
#  EMAIL
# ════════════════════════════════════════════════════════════

# Leave SMTP_HOST blank to disable email completely (alerts just log to console).
# To see emails locally, install Mailhog:
#   https://github.com/mailhog/MailHog/releases  → MailHog_windows_amd64.exe
#   Run it, then set SMTP_HOST=localhost SMTP_PORT=1025
#   View emails at http://localhost:8025
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM_ADDRESS=alerts@finsight.local
USE_SES=false
SES_FROM_ADDRESS=alerts@finsight.local
APP_URL=http://localhost:3000

# ── SeaweedFS (disabled — use local storage instead) ──────────
USE_SEAWEEDFS=false
SEAWEEDFS_S3_ENDPOINT=


# ════════════════════════════════════════════════════════════
#  OBSERVABILITY (optional, disabled by default)
# ════════════════════════════════════════════════════════════

# Prometheus metrics endpoint — disable to save memory in local dev
ENABLE_PROMETHEUS=false
PROMETHEUS_METRICS_PATH=/metrics


# ── SEC EDGAR poller ──────────────────────────────────────────
USE_EDGAR_POLLER=false
EDGAR_POLL_INTERVAL_SECONDS=3600
EDGAR_USER_AGENT=FinSight-AI/0.1 (contact@finsight.local)


# ── Re-ranker ─────────────────────────────────────────────────
# Downloads ~85 MB on first use, cached in .cache/
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5
RETRIEVER_TOP_K=20
RRF_K=60


# ── Document processing ───────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE_CHARS=800
CHUNK_OVERLAP_CHARS=150


# ── OpenAI (optional — only for document comparison feature) ──
# Leave blank to use Groq as fallback for comparisons too.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini
