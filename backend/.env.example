# ============================================================
# FinSight AI — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in every value before running.
# NEVER commit .env to git. .env is already in .gitignore.
#
# Quick start (local dev with Docker Compose):
#   cp .env.example .env
#   # Fill in CLERK_* values from your Clerk dashboard
#   docker-compose up
# ============================================================


# ── App ──────────────────────────────────────────────────────
APP_NAME=FinSight AI
APP_VERSION=0.1.0
# development | staging | production
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO


# ── API ──────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ── Database ─────────────────────────────────────────────────
# asyncpg driver — used by the FastAPI app
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://finsight:finsight_dev@localhost:5432/finsight

# Pool tuning (defaults are fine for local dev)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── PostgreSQL (used by Docker Compose to initialise the DB container) ──
POSTGRES_USER=finsight
POSTGRES_PASSWORD=finsight_dev
POSTGRES_DB=finsight


# ── Clerk Authentication ──────────────────────────────────────
# Get these from: https://dashboard.clerk.com → your app → API Keys
#
# Secret key   — server-side only, NEVER expose to the browser
CLERK_SECRET_KEY=sk_test_REPLACE_ME
#
# Publishable key — safe to expose to the frontend
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
#
# JWKS endpoint — verify JWT signatures (default is correct for most apps)
CLERK_JWKS_URL=https://api.clerk.dev/v1/jwks
#
# Audience claim in the JWT (your Clerk Frontend API URL)
# Find it at: Clerk dashboard → API Keys → Frontend API URL
# Example: https://your-app.clerk.accounts.dev
CLERK_JWT_AUDIENCE=


# ── AWS ───────────────────────────────────────────────────────
AWS_REGION=us-east-1

# For LocalStack (local dev): use "test" / "test"
# For real AWS: use IAM access keys with least-privilege policy
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# LocalStack endpoint — comment out / leave empty for real AWS
AWS_ENDPOINT_URL=http://localhost:4566

# S3
S3_BUCKET_NAME=finsight-documents
S3_PRESIGNED_URL_EXPIRY=3600

# SQS
# LocalStack format: http://localhost:4566/000000000000/<queue-name>
# Real AWS format:   https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>
SQS_DOCUMENT_QUEUE_URL=http://localhost:4566/000000000000/finsight-documents


# ── OpenAI (Week 3 — RAG query generation) ────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o


# ── Pinecone (Week 3 — vector store) ──────────────────────────
# Get from: https://app.pinecone.io
# Create ONE index with these EXACT settings:
#   Name:       finsight-docs
#   Dimensions: 3072
#   Metric:     cosine
#   Type:       Serverless  (free tier)
#   Cloud:      AWS
#   Region:     us-east-1
PINECONE_API_KEY=REPLACE_ME
PINECONE_INDEX_NAME=finsight-docs
PINECONE_DIMENSION=3072
PINECONE_METRIC=cosine
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Redis (BM25 sparse index cache) ───────────────────────────
# Docker Compose starts Redis automatically on port 6379.
# For external Redis (e.g. Redis Cloud free tier):
#   REDIS_URL=redis://default:<password>@<host>:<port>/0
REDIS_URL=redis://localhost:6379/0
REDIS_BM25_TTL=604800

# ── Re-ranker ─────────────────────────────────────────────────
# Model downloads ~85 MB on first use. Cached in ~/.cache/torch/
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5
RETRIEVER_TOP_K=20
RRF_K=60


# ── Document processing ───────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE_CHARS=800
CHUNK_OVERLAP_CHARS=150
