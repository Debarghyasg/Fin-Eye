# ============================================================
#  FinSight AI — No-Docker Windows 11 environment
#  Copy this file to  backend/.env  then fill in the 3 keys below.
#
#  REQUIRED (takes < 3 minutes to get both, both are free):
#    CLERK_SECRET_KEY       → https://dashboard.clerk.com  → API Keys
#    CLERK_PUBLISHABLE_KEY  → same page
#    GROQ_API_KEY           → https://console.groq.com      → API Keys
#
#  Everything else is pre-set for a local Windows 11 machine.
#  Do NOT change anything unless the troubleshooting guide tells you to.
# ============================================================


# ── Application ───────────────────────────────────────────────
APP_NAME=FinSight AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ── PostgreSQL (local, installed from postgresql.org) ─────────
# The URL matches the database/user you created in the setup guide.
DATABASE_URL=postgresql+asyncpg://finsight:finsight_dev@localhost:5432/finsight
POSTGRES_USER=finsight
POSTGRES_PASSWORD=finsight_dev
POSTGRES_DB=finsight


# ── Clerk Authentication ───────────────────────────────────────
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_JWKS_URL=https://api.clerk.dev/v1/jwks
CLERK_JWT_AUDIENCE=


# ── Groq LLM (free — 14 400 req/day) ──────────────────────────
GROQ_API_KEY=gsk_REPLACE_ME
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant


# ── OpenAI (optional — only for document comparison) ──────────
# Leave blank; Groq is used as fallback for all features.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini


# ── Local embeddings (downloads ~90 MB on first run) ──────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384


# ── Qdrant vector store (qdrant.exe, no install needed) ───────
# Download: https://github.com/qdrant/qdrant/releases
# Run it:   cd C:\qdrant && .\qdrant.exe
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=finsight_chunks
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
QDRANT_SPARSE_MODEL=Qdrant/bm25


# ── Redis — NOT NEEDED ────────────────────────────────────────
# Redis is not used anywhere in the codebase. The old BM25 cache
# that lived in Redis was replaced by Qdrant native sparse vectors.
# These lines are kept only so old .env files don't break.
REDIS_URL=redis://localhost:6379/0
REDIS_BM25_TTL=604800


# ── Celery — ALWAYS_EAGER=true means NO broker/worker needed ──
# Tasks run inline inside the FastAPI process.
# Upload will block for ~10-30 s while the document indexes.
# Set to false only if you install RabbitMQ separately.
CELERY_TASK_ALWAYS_EAGER=true
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=rpc://
CELERY_TASK_DEFAULT_QUEUE=finsight
EDGAR_POLLER_BEAT_NAME=edgar-poll-every-hour


# ── File storage (local folder, no S3 or SeaweedFS needed) ────
USE_S3=false
USE_SEAWEEDFS=false
LOCAL_STORAGE_PATH=./uploads


# ── AWS (all disabled — not needed for local dev) ─────────────
USE_SQS=false
USE_DYNAMODB=false
USE_SES=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=unused
AWS_SECRET_ACCESS_KEY=unused
AWS_ENDPOINT_URL=
S3_BUCKET_NAME=finsight-documents
SQS_DOCUMENT_QUEUE_URL=
DYNAMODB_AUDIT_TABLE=finsight-query-audit
DYNAMODB_TTL_DAYS=2555
SES_FROM_ADDRESS=alerts@finsight.local
SEAWEEDFS_S3_ENDPOINT=


# ── Encryption (disabled in local dev — no key needed) ────────
FERNET_KEY=
ENCRYPT_AT_REST=false


# ── PII scanner (Presidio + spaCy, runs 100% locally) ─────────
# Needs spaCy model (run once): python -m spacy download en_core_web_sm
USE_PRESIDIO=true
PRESIDIO_LANGUAGE=en
PRESIDIO_MIN_SCORE=0.5
PRESIDIO_SPACY_MODEL=en_core_web_sm


# ── Audit log retention ───────────────────────────────────────
AUDIT_LOG_RETENTION_YEARS=7


# ── Email (disabled — alerts are logged to console only) ──────
# To see real emails locally, install MailHog:
# https://github.com/mailhog/MailHog/releases → MailHog_windows_amd64.exe
# Then set: SMTP_HOST=localhost  SMTP_PORT=1025
# View captured emails at: http://localhost:8025
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM_ADDRESS=alerts@finsight.local
APP_URL=http://localhost:3000


# ── Prometheus metrics (disabled to save memory) ──────────────
ENABLE_PROMETHEUS=false
PROMETHEUS_METRICS_PATH=/metrics


# ── SEC EDGAR poller (disabled by default) ────────────────────
USE_EDGAR_POLLER=false
EDGAR_POLL_INTERVAL_SECONDS=3600
EDGAR_USER_AGENT=FinSight-AI/0.1 (contact@finsight.local)


# ── Re-ranker (~85 MB download on first use) ──────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5
RETRIEVER_TOP_K=20
RRF_K=60


# ── Document processing ───────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE_CHARS=800
CHUNK_OVERLAP_CHARS=150
